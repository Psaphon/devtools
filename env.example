# Dev Tools Environment
# Copy to /media/secrets/devtools/env and fill in your values
# install.sh will symlink this to ~/.config/dtl/env
# Permissions: chmod 600 (owner read/write only)

# Note: Claude Code uses OAuth (claude login), no API key needed.

# Git identity (used inside AI containers for commits)
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=
